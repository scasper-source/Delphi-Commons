  "type": "module",
  "scripts": {
    "dev": "npm run build && node dist/index.js",
    "build": "tsc",
    "test": "npm run build && node ../scripts/run-tests.mjs \"tests/*.test.mjs\"",
    "security:audit": "npm audit --audit-level=high",
    "start": "node dist/index.js",
    "test:backup-restore-rehearsal": "npm run build && node ../scripts/run-tests.mjs \"tests/backupRestoreRehearsal.test.mjs\"",
    "test:incident-workflow": "npm run build && node ../scripts/run-tests.mjs \"tests/incidentWorkflowPhase1.test.mjs\"",
    "security:verify:deployment": "node ../scripts/verify-deployment-security.mjs local",
    "test:phase3-magic-link-browser-scaffold": "npm run build && node ../docs/qc/full-mock-trial/run_phase3_magic_link_browser_scaffold_local.mjs"
  },
  "dependencies": {
    "fastify": "^5.7.4",
    "nanoid": "^5.1.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
