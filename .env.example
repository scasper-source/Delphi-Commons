# Delphi Commons local/dev mock-testing environment example
#
# Boundary statement:
# Delphi Commons is suitable only for controlled mock-trial use with synthetic or
# low-risk test data in local, development, or staging environments. It is not
# approved or ready for production deployment or real human-subjects research.
#
# Use placeholders only. Do not put real secrets, credentials, participant data,
# consent records, identity mappings, real exports, or private institutional data
# in this file.

NODE_ENV=development
HOST=127.0.0.1
PORT=3001
EDELPHI_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Local-only runtime paths. Treat these directories as sensitive and do not commit
# their contents.
EDELPHI_DATA_DIR=server/data
EDELPHI_AUDIT_DIR=server/audit
EDELPHI_BACKUP_DIR=server/backups
EDELPHI_DATABASE_PATH=server/data/edelphi.sqlite

# Development/demo behavior.
EDELPHI_SEED_DEMO_USERS=true
EDELPHI_DEMO_GOVERNANCE_ASSIGNMENTS=true
EDELPHI_AUTH_REQUIRE_SESSION=false

# Local security/rate-limit settings.
EDELPHI_SECURE_COOKIES=false
EDELPHI_BODY_LIMIT_BYTES=262144
EDELPHI_RATE_LIMIT_WINDOW_MS=60000
EDELPHI_RATE_LIMIT_AUTH_MAX=10
EDELPHI_RATE_LIMIT_MUTATION_MAX=300
EDELPHI_RATE_LIMIT_INVITATION_MAX=120

# AI connector key encryption placeholder. Do not use a real production secret.
EDELPHI_AI_KEY_ENCRYPTION_SECRET=changeme-dev-only

# SMS remains mock by default for local/dev testing.
EDELPHI_MAGIC_LINK_TTL_MINUTES=60
EDELPHI_PHONE_OTP_TTL_MINUTES=10
EDELPHI_SMS_PROVIDER=mock
EDELPHI_SMS_WEBHOOK_SECRET=changeme-dev-only

# Twilio real-SMS integration placeholders. Leave unset unless a governed real
# SMS test has approved registration, consent, privacy, and human-testing scope.
# Do not commit real Twilio credentials.
# EDELPHI_SMS_PROVIDER=twilio
# EDELPHI_ENABLE_REAL_SMS=false
# EDELPHI_REAL_SMS_ACK=
# EDELPHI_PUBLIC_PARTICIPANT_ORIGIN=https://participant.example.test
# EDELPHI_TWILIO_WEBHOOK_BASE_URL=https://hooks.example.test
# EDELPHI_TWILIO_STATUS_CALLBACK_URL=
# EDELPHI_TWILIO_CONNECT_URL=https://console.twilio.com/us1/develop/sms/services
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_MESSAGING_SERVICE_SID=
